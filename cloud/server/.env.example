# Server
PORT=3000
HOST=0.0.0.0
BASE_DOMAIN=tonesintime.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_ID_BASIC=price_basic_plan_id
STRIPE_PRICE_ID_PRO=price_pro_plan_id

# Icecast defaults
ICECAST_ADMIN_PASSWORD=admin-password-change-this
ICECAST_IMAGE=tonesintime/icecast:latest
ICECAST_PORT_RANGE_START=8001
ICECAST_PORT_RANGE_END=9000
ICECAST_NETWORK=tonesintime

# Database
DB_PATH=./data/tonesintime.db
