{
  "name": "tonesintime",
  "version": "1.0.0",
  "description": "Standalone audio broadcast server - captures audio interface and streams to any platform",
  "author": "JioCreates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JioCreates/TonesinTime-Broadcaster.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.tonesintime.app",
    "productName": "TonesinTime",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dir"
      ],
      "icon": "build/icon.icns",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "lamejs": "^1.2.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
